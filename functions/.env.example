# Exemplo de configuração de ambiente para o SendGrid
# Copie este arquivo para .env e preencha com seus valores reais

# Chave de API do SendGrid
SENDGRID_API_KEY=SG.sua_chave_aqui

# Email remetente padrão (opcional, pode ser configurado por empresa)
DEFAULT_SENDER_EMAIL=marcellomatosxads@gmail.com

# Nome do remetente padrão (opcional)
DEFAULT_SENDER_NAME=NEXBOOK
