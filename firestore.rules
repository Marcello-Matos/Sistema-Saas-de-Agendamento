rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Usuários
    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // Função auxiliar
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // Collections protegidas (exigem userId no documento)
    match /professionals/{docId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId)
                    && request.resource.data.userId == resource.data.userId;
    }

    match /services/{docId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId)
                    && request.resource.data.userId == resource.data.userId;
    }

    match /clients/{docId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId)
                    && request.resource.data.userId == resource.data.userId;
    }

    match /appointments/{docId} {
      allow read, delete: if isOwner(resource.data.userId);
      allow create: if isOwner(request.resource.data.userId);
      allow update: if isOwner(resource.data.userId)
                    && request.resource.data.userId == resource.data.userId;
    }

    // ============================================
    // SETTINGS - REGRAS ESPECÍFICAS (NÃO USA userId)
    // ============================================
    match /settings/{userId} {
      // Permite leitura/escrita baseado no ID do documento (que é o UID)
      allow read, write: if request.auth != null && request.auth.uid == userId;
      
      // Não precisa verificar campo userId porque o ID já é o identificador
    }
  }
}